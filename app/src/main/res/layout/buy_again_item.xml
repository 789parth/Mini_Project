<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="14dp"
    app:cardCornerRadius="18dp"
    app:cardElevation="6dp"
    android:backgroundTint="@android:color/white">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="14dp">

        <!-- Product Image -->
        <ImageView
            android:id="@+id/imageBuyAgain"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:scaleType="centerCrop"
            android:src="@drawable/menu1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>

        <!-- Product Name -->
        <TextView
            android:id="@+id/foodNameBuyAgain"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Tomato (1kg)"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#222222"
            android:layout_marginStart="12dp"
            app:layout_constraintStart_toEndOf="@id/imageBuyAgain"
            app:layout_constraintTop_toTopOf="@id/imageBuyAgain"
            app:layout_constraintEnd_toStartOf="@id/btnBuyAgain"/>

        <!-- Price -->
        <TextView
            android:id="@+id/priceBuyAgain"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="₹40"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#FF5722"
            android:layout_marginStart="12dp"
            android:layout_marginTop="6dp"
            app:layout_constraintStart_toStartOf="@id/foodNameBuyAgain"
            app:layout_constraintTop_toBottomOf="@id/foodNameBuyAgain"/>

        <!-- Buy Again Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBuyAgain"
            android:layout_width="100dp"
            android:layout_height="36dp"
            android:text="Buy Again"
            android:textSize="12sp"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            app:cornerRadius="18dp"
            app:backgroundTint="#FF5722"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>
