<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardCornerRadius="22dp"
    app:cardElevation="10dp"
    app:strokeWidth="0dp"
    android:layout_marginStart="12dp"
    android:layout_marginEnd="16dp"
    android:backgroundTint="@android:color/white">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Product Image -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/imageView5"
                android:layout_width="75dp"
                android:layout_height="75dp"
                android:background="@drawable/addtocartshape"
                android:padding="8dp"
                android:scaleType="centerCrop" />
        </LinearLayout>

        <!-- Product Name -->
        <TextView
            android:id="@+id/foodNamePopuler"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Tomato (1kg)"
            android:textColor="#1A1A1A"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/btnOrder"
            app:layout_constraintStart_toEndOf="@id/imageView5"
            app:layout_constraintTop_toTopOf="@id/imageView5" />

        <!-- Product Description -->
        <TextView
            android:id="@+id/textViewDesc"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_marginTop="4dp"
            android:ellipsize="end"
            android:maxLines="2"
            android:text="Fresh organic grocery item directly from farm."
            android:textColor="#777777"
            android:textSize="13sp"
            app:layout_constraintEnd_toStartOf="@id/btnOrder"
            app:layout_constraintStart_toStartOf="@id/foodNamePopuler"
            app:layout_constraintTop_toBottomOf="@id/foodNamePopuler" />

        <!-- Price -->
        <TextView
            android:id="@+id/PricePopuar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_marginTop="8dp"
            android:text="₹60"
            android:textColor="#FF5722"
            android:textSize="15sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@id/textViewDesc"
            app:layout_constraintTop_toBottomOf="@id/textViewDesc" />

        <!-- Order Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOrder"
            android:layout_width="95dp"
            android:layout_height="38dp"
            android:text="Order"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="13sp"
            android:textStyle="bold"
            app:backgroundTint="#6C5CE7"
            app:cornerRadius="22dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
