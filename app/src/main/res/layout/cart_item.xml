<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="18dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/theme_medium_gray"
    app:strokeWidth="2dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:padding="8dp">

        <!-- Image Container styled like DetailsActivity -->
        <androidx.cardview.widget.CardView
            android:id="@+id/imageCard"
            android:layout_width="80dp"
            android:layout_height="80dp"
            app:cardBackgroundColor="@color/category_card_bg"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/cartImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="0dp"
                android:scaleType="centerInside"
                tools:src="@drawable/menu1" />
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/productName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:ellipsize="end"
            android:fontFamily="@font/madaniarabic_bold"
            android:maxLines="1"
            android:text="Product Name"
            android:textColor="@color/theme_black"
            android:textSize="18sp"
            app:layout_constraintEnd_toStartOf="@+id/cardView4"
            app:layout_constraintStart_toEndOf="@+id/imageCard"
            app:layout_constraintTop_toTopOf="@+id/imageCard" />

        <TextView
            android:id="@+id/productWeight"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/madaniarabic_regular"
            android:text="500 gm"
            android:textColor="@color/theme_medium_gray"
            android:textSize="14sp"
            app:layout_constraintStart_toStartOf="@+id/productName"
            app:layout_constraintTop_toBottomOf="@+id/productName" />

        <TextView
            android:id="@+id/productPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/madaniarabic_bold"
            android:text="₹0"
            android:textColor="@color/theme_orange"
            android:textSize="18sp"
            app:layout_constraintBottom_toBottomOf="@+id/imageCard"
            app:layout_constraintStart_toStartOf="@+id/productName"
            app:layout_constraintTop_toBottomOf="@+id/productWeight" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardView4"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:elevation="0dp"
            app:cardCornerRadius="18dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:strokeColor="@color/red">

            <ImageView
                android:id="@+id/delete"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="@color/white"
                android:padding="4dp"
                app:srcCompat="@drawable/delete_icon"
                app:tint="@color/red" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Quantity Control styled like elegantNumbers in DetailsActivity -->
        <LinearLayout
            android:id="@+id/quantityControl"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:background="@drawable/button_gradient_bg"
            android:backgroundTint="@color/theme_light_orange"
            android:gravity="center"
            android:orientation="horizontal"
            android:padding="5dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:id="@+id/minus"
                android:layout_width="32dp"
                android:layout_height="32dp"
                app:srcCompat="@drawable/minus_icon" />

            <TextView
                android:id="@+id/quantity"
                android:layout_width="30dp"
                android:layout_height="wrap_content"
                android:fontFamily="@font/madaniarabic_bold"
                android:text="1"
                android:textAlignment="center"
                android:textColor="@color/theme_black"
                android:textSize="16sp" />

            <ImageView
                android:id="@+id/plus"
                android:layout_width="32dp"
                android:layout_height="32dp"
                app:srcCompat="@drawable/plus_icon" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
